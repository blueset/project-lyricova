{
  "name": "root",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "typecheck:native": "turbo run typecheck:native",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "knip:production": "knip --production --strict"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "postcss": "8.5.16"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.12.0",
    "next": "^16.2.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript/native-preview": "7.0.0-dev.20260703.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "prettier": "^3.9.4",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
