{
  "name": "@lyricova/components",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "npm run codegen && tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "lint": "eslint src",
    "dev": "concurrently \"npm:codegen:watch\" \"tsc -w\" \"tsc-alias -w\"",
    "codegen": "graphql-codegen --config codegen.ts && graphql-codegen --config codegen.schema.ts",
    "codegen:watch": "nodemon --watch ../api/schema.graphql --ext graphql --exec \"graphql-codegen --config codegen.schema.ts && graphql-codegen --config codegen.ts --watch\"",
    "clean": "rimraf build",
    "test": "vitest run"
  },
  "dependencies": {
    "@apollo/client": "^4.2.5",
    "@better-auth/passkey": "^1.6.23",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/clarity": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-table": "^8.21.2",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.4",
    "lodash": "^4.18.1",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.249.3",
    "radix-ui": "^1.4.2",
    "react-day-picker": "^9.6.6",
    "react-hook-form": "^7.55.0",
    "react-merge-refs": "^2.1.1",
    "react-select": "^5.10.1",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.6",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.1.0",
    "tw-animate-css": "^1.2.5",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.3",
    "tsc-alias": "^1.8.8",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./components/*": {
      "import": "./build/components/*.js",
      "require": "./build/components/*.js",
      "types": "./build/components/*.d.ts"
    },
    "./utils": "./src/utils/index.ts",
    "./gql": "./src/gql/index.ts",
    "./gql/graphql": "./src/gql/graphql.ts",
    "./gql/schema": "./src/gql/schema.ts",
    "./gql/*": "./src/gql/*",
    "./hooks/*": {
      "import": "./build/hooks/*.js",
      "require": "./build/hooks/*.js",
      "types": "./build/hooks/*.d.ts"
    },
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./postcss.config": "./postcss.config.mjs",
    "./styles/*.scss": "./src/styles/*.scss",
    "./styles/*.css": "./src/styles/*.css"
  }
}
