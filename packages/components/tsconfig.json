{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationDir": "./build",
    "outDir": "./build",
    "rootDir": "./src",
    "sourceMap": true,
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@lyricova/components/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
