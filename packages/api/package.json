    "mecab-async": "^0.1.2",
    "mime": "^3.0.0",
    "multer": "^2.2.0",
    "mysql2": "^3.9.8",
    "node-id3": "^0.2.1",
    "notistack": "^3.0.2",
    "novel-segment": "^2.7.53",
    "p-limit": "^3.1.0",
    "passport": "^0.6.0",
    "passport-fido2-webauthn": "^0.1.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pinyin": "^4.0.0-alpha.2",
    "posthog-node": "^4.18.0",
    "prop-types": "^15.7.2",
    "reflect-metadata": "^0.1.13",
    "rss": "^1.2.2",
    "sanitize-filename": "^1.6.3",
    "satori": "^0.4.1",
    "simple-statistics": "^7.8.8",
    "slugify": "^1.6.6",
    "split": "^1.0.1",
    "stream-combiner": "^0.2.2",
    "stream-filter": "^2.1.0",
    "swagger-jsdoc": "^6.2.8",
    "tempy": "^1.0.1",
    "through": "^2.3.8",
    "uuid": "^14.0.0",
    "winston": "^3.2.1",
    "ws": "^8.21.0",
    "yt-dlp-wrap-plus": "^2.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@jest/globals": "^30.4.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.0.1",
    "@types/concat-stream": "^2.0.3",
    "@types/cors": "^2.8.17",
    "@types/errorhandler": "^1.5.0",
    "@types/express": "^5.0.6",
    "@types/express-flash": "^0.0.2",
    "@types/express-mysql-session": "^3.0.8",
    "@types/express-session": "^1.15.16",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
