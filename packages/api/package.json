{
  "name": "@lyricova/api",
  "version": "2.1.0",
  "description": "API server for Lyricova blog and jukebox.",
  "main": "./dist/server.js",
  "typings": "./dist/server.d.ts",
  "module": "./dist/server.js",
  "scripts": {
    "start": "npm run serve",
    "build": "npm run build:ts && npm run lint && npm run posthog",
    "serve": "node dist/server.js",
    "dev:node": "nodemon dist/server.js",
    "dev": "concurrently -n node,tscr,emit -c green,blue,yellow npm:dev:node npm:dev:ts npm:pothos:emit:watch",
    "build:ts": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "dev:ts": "tsc -w",
    "pothos:emit:watch": "nodemon --watch dist/graphql --ext js --delay 1 --exec \"node scripts/emit-pothos-schema.mjs schema.graphql\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.{js,ts}\" --quiet --fix",
    "debug": "npm run build && npm run dev:debug-b",
    "dev:node-debug": "nodemon --inspect dist/server.js",
    "dev:debug-b": "npm run dev serve-debug",
    "dev:debug": "concurrently -n node,tscr -c green,blue npm:dev:node-debug npm:dev:ts",
    "posthog": "posthog-cli sourcemap inject --directory dist && posthog-cli sourcemap upload --directory dist",
    "schema:check": "node scripts/schema-parity.mjs",
    "openapi": "node scripts/emit-openapi.mjs && openapi-typescript openapi.json -o src/openapi/schema.ts",
    "pothos:emit": "tsc ; node scripts/emit-pothos-schema.mjs",
    "pothos:check": "npm run pothos:emit && node scripts/schema-parity.mjs schema.graphql.golden schema.pothos.graphql",
    "test": "jest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blueset/project-lyricova",
    "directory": "packages/jukebox"
  },
  "author": "Eana Hufwe",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/blueset/project-lyricova/issues"
  },
  "homepage": "https://github.com/blueset/project-lyricova#readme",
  "exports": {
    "./graphql/types": {
      "types": "./dist/graphql/types.d.ts"
    },
    "./openapi": "./src/openapi/index.ts",
    "./vocadb": {
      "types": "./src/types/vocadb.d.ts"
    }
  },
  "dependencies": {
    "@ai-sdk/azure": "^3.0.84",
    "@ai-sdk/openai": "^3.0.80",
    "@apollo/server": "^5.5.0",
    "@applemusic-like-lyrics/react": "^0.1.5",
    "@as-integrations/express5": "^1.1.2",
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.10.6",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.10.6",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@posthog/cli": "^0.7.34",
    "@pothos/core": "^4.13.0",
    "@pothos/plugin-drizzle": "^0.8.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@resvg/resvg-js": "^2.4.1",
    "@scalar/express-api-reference": "^0.8.21",
    "ai": "^6.0.219",
    "autosuggest-highlight": "^3.1.1",
    "base64url": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "budoux": "^0.7.0",
    "cheerio": "^1.0.0-rc.3",
    "colorthief": "^2.4.0",
    "compression": "^1.7.4",
    "concat-stream": "^2.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "errorhandler": "^1.5.1",
    "eslint": "^9.39.2",
    "express": "^5.2.1",
    "express-flash": "0.0.2",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.17.1",
    "express-validator": "^7.3.2",
    "fast-diff": "^1.3.0",
    "fetch-sse": "^1.1.2",
    "ffprobe-client": "^1.1.6",
    "final-form": "^4.20.10",
    "final-form-arrays": "^3.1.0",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^6.0.4",
    "hasha": "^5.1.0",
    "jsdom": "^26.0.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.18.1",
    "lusca": "^1.6.1",
