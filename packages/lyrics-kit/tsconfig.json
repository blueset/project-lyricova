{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ESNext"],
    "types": ["node", "vitest/globals"],
    "strict": true,
    "outDir": "build/main",
    "rootDir": "src",
    "declaration": true,
    "inlineSourceMap": true,

    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "pretty": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules/**"],
  "compileOnSave": false,
  "typedocOptions": {
    "mode": "modules",
    "out": "docs"
  }
}
